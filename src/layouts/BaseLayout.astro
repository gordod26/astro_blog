---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "A personal site and blog." } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <div class="site-wrapper">
      <header>
        <a href="/" class="site-title">David</a>
        <nav>
          <a href="/" class={currentPath === "/" ? "active" : ""}>Home</a>
          <a href="/about" class={currentPath.startsWith("/about") ? "active" : ""}>About</a>
          <a href="/blog" class={currentPath.startsWith("/blog") ? "active" : ""}>Blog</a>
        </nav>
      </header>

      <main>
        <slot />
      </main>

      <footer>
        <p>&copy; {new Date().getFullYear()} David. All rights reserved.</p>
      </footer>
    </div>
  </body>
</html>

<style is:global>
  @import "../styles/global.css";
</style>
